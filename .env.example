# ============================================================
# Atlas Farmacológico Veterinario — Variables de Entorno
# Copia este archivo a .env y completa los valores reales.
# NUNCA subas .env a un repositorio público.
# ============================================================

# ── Supabase (OBLIGATORIO) ───────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic API Key (SOLO para desarrollo local sin Edge Function) ─
# En producción la clave vive en Supabase Secrets, no aquí.
# Panel Supabase → Settings → Edge Functions → Secrets → ANTHROPIC_API_KEY
# Para desarrollo local con 'npm run dev', puedes poner la clave aquí:
VITE_ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
